modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 45000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 21486
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "f4d1563ec79e7fdce3ee31543a80f4b45d8006014a22e3c34c73de32bba92c2b56e05aa5b959f22a4ed1666dedce3541"
